# Notion integration token (Bearer). Create one at https://www.notion.so/my-integrations
# and connect it to the "Delacosta · CRM" page so it can read/write the databases.
NOTION_TOKEN=ntn_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Notion API version. Data sources require a recent version.
NOTION_VERSION=2025-09-03

# Server
PORT=3000
NODE_ENV=development

# Comma-separated list of allowed CORS origins. Use * to allow all.
CORS_ORIGIN=*

# Optional: protect write endpoints with a shared key sent as `x-api-key` header.
# Leave empty to disable auth (e.g. local development).
API_KEY=
