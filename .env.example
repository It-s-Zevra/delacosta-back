# Notion integration token (Bearer). Create one at https://www.notion.so/my-integrations
# and connect it to the "Delacosta · CRM" page so it can read/write the databases.
NOTION_TOKEN=ntn_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Notion API version. Data sources require a recent version.
NOTION_VERSION=2025-09-03

# Server
PORT=3000
NODE_ENV=development

# Comma-separated list of allowed CORS origins. Use * to allow all.
CORS_ORIGIN=*

# Optional: protect write endpoints with a shared key sent as `x-api-key` header.
# Leave empty to disable auth (e.g. local development).
API_KEY=

# Notion data_source_id of each base. Optional: if omitted, the app uses the
# current workspace defaults baked into src/config/env.ts. Only set these if the
# bases are recreated in Notion.
DS_CATEGORIAS=5d01b258-839d-4514-bd8b-36c490f87d0a
DS_PRODUCTOS=c7dfe85f-8ff9-426e-be31-619d0206733c
DS_CLIENTES=473aefac-4c0f-4901-b291-6fa13d2a6397
DS_PEDIDOS=43f9a040-313f-4ef6-9a98-841e979a9cf5
DS_ITEMS=2ec5fe50-c5a1-4f6b-a779-4982e742cb1e

# ─── Mailer (emails de confirmación de pedido) ──────────────────────────────
# Mismas credenciales que mailer-backend (cuenta Gmail de Zevra).
# Copiar los valores del .env de mailer-backend.

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# Gmail API OAuth2 — fallback si Railway bloquea SMTP saliente (opcional).
# Copiar de mailer-backend si está configurado.
# GMAIL_CLIENT_ID=
# GMAIL_CLIENT_SECRET=
# GMAIL_REFRESH_TOKEN=

# Email del admin de Delacosta — a dónde llegan las alertas de cada pedido.
TENANT_DELACOSTA_EMAIL=
